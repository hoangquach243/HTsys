// GoHost Clone — Full Prisma Schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PROPERTY (Multi-tenant root)
// ============================================
model Property {
  id                       String   @id @default(cuid())
  name                     String
  phone                    String?
  email                    String?
  address                  String?
  logo                     String?
  checkInTime              String   @default("14:00")
  checkOutTime             String   @default("12:00")
  timezone                 String   @default("Asia/Ho_Chi_Minh")
  currency                 String   @default("VND")
  allowHourly              Boolean  @default(false)
  requirePayBeforeCheckout Boolean  @default(false)
  calendarColorMode        String   @default("status") // status | source
  calendarDefaultView      String   @default("week")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  // Relations
  users          User[]
  roomTypes      RoomType[]
  bookings       Booking[]
  guests         Guest[]
  services       Service[]
  tasks          Task[]
  taskTemplates  TaskTemplate[]
  expenses       Expense[]
  labels         Label[]
  categories     Category[]
  bookingSources BookingSource[]
  paymentMethods PaymentMethod[]
  bankAccounts   BankAccount[]
  otaChannels    OtaChannel[]
  emailTemplates EmailTemplate[]
  emailFlows     EmailFlow[]

  @@map("properties")
}

// ============================================
// AUTH & USERS
// ============================================
enum UserRole {
  ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(RECEPTIONIST)
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  propertyId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payments        Payment[] @relation("PaymentStaff")
  assignedTasks   Task[]    @relation("TaskAssignee")
  createdBookings Booking[] @relation("BookingCreator")

  @@map("users")
}

// ============================================
// ROOM MANAGEMENT
// ============================================
enum RoomTypeKind {
  ROOM
  DORM
}

model RoomType {
  id           String       @id @default(cuid())
  name         String
  code         String
  kind         RoomTypeKind @default(ROOM)
  description  String?
  maxAdults    Int          @default(2)
  maxChildren  Int          @default(1)
  maxInfants   Int          @default(1)
  basePrice    Float        @default(0)
  weekendPrice Float?
  amenities    String[]     @default([])
  photos       String[]     @default([])
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  propertyId   String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms        Room[]
  bookingRooms BookingRoom[]
  ratePlans    RatePlan[]
  otaMappings  OtaMapping[]

  @@unique([propertyId, code])
  @@map("room_types")
}

model Room {
  id         String     @id @default(cuid())
  roomNumber String
  area       String?
  floor      String?
  status     RoomStatus @default(AVAILABLE)
  notes      String?
  roomTypeId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  roomType     RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  bookingRooms BookingRoom[]
  tasks        Task[]

  @@unique([roomTypeId, roomNumber])
  @@map("rooms")
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  BLOCKED
}

model RatePlan {
  id           String   @id @default(cuid())
  name         String
  basePrice    Float
  weekendPrice Float?
  isDefault    Boolean  @default(false)
  roomTypeId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@map("rate_plans")
}

// ============================================
// BOOKINGS
// ============================================
enum BookingStatus {
  NEW
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model Booking {
  id            String        @id @default(cuid())
  code          String        @unique
  status        BookingStatus @default(NEW)
  paymentStatus PaymentStatus @default(UNPAID)
  source        String        @default("walk-in")
  otaCode       String?
  checkIn       DateTime
  checkOut      DateTime
  nights        Int           @default(1)
  adults        Int           @default(1)
  children      Int           @default(0)
  infants       Int           @default(0)
  arrivalTime   String?
  departureTime String?
  totalAmount   Float         @default(0)
  paidAmount    Float         @default(0)
  commission    Float         @default(0)
  notes         String?
  guestId       String
  propertyId    String
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  guest         Guest          @relation(fields: [guestId], references: [id])
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("BookingCreator", fields: [createdById], references: [id])
  bookingRooms  BookingRoom[]
  payments      Payment[]
  serviceUsages ServiceUsage[]
  tasks         Task[]
  bookingLabels BookingLabel[]

  @@map("bookings")
}

model BookingRoom {
  id         String   @id @default(cuid())
  bookingId  String
  roomId     String?
  roomTypeId String
  checkIn    DateTime
  checkOut   DateTime
  price      Float    @default(0)
  createdAt  DateTime @default(now())

  // Relations
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room     Room?    @relation(fields: [roomId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@map("booking_rooms")
}

// ============================================
// GUESTS / CRM
// ============================================
enum Gender {
  MALE
  FEMALE
  OTHER
}

model Guest {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  email       String?
  idNumber    String? // CCCD / Passport
  nationality String?
  gender      Gender?
  dob         DateTime?
  language    String?   @default("vi")
  notes       String?
  totalStays  Int       @default(0)
  totalNights Int       @default(0)
  propertyId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  guestLabels GuestLabel[]

  @@map("guests")
}

// ============================================
// PAYMENTS & FINANCE
// ============================================
model Payment {
  id        String   @id @default(cuid())
  amount    Float
  method    String   @default("cash") // cash, transfer, card, momo, vnpay
  note      String?
  paidAt    DateTime @default(now())
  bookingId String
  staffId   String?
  createdAt DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  staff   User?   @relation("PaymentStaff", fields: [staffId], references: [id])

  @@map("payments")
}

model Expense {
  id                String    @id @default(cuid())
  category          String
  description       String?
  amount            Float
  date              DateTime  @default(now())
  isRecurring       Boolean   @default(false)
  recurringInterval String? // monthly, quarterly, yearly
  recurringEndDate  DateTime?
  isActive          Boolean   @default(true)
  propertyId        String
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ============================================
// SERVICES
// ============================================
enum PricingMode {
  FIXED // Cố định
  PER_NIGHT // Theo ngày
  PER_PERSON // Theo người
  PER_PERSON_NIGHT // Theo người/ngày
}

enum ServiceType {
  SERVICE
  SURCHARGE
}

model Service {
  id          String      @id @default(cuid())
  name        String
  code        String?
  group       String? // Ăn uống, Giặt ủi, Vận chuyển...
  price       Float       @default(0)
  pricingMode PricingMode @default(FIXED)
  description String?
  type        ServiceType @default(SERVICE)
  isActive    Boolean     @default(true)
  propertyId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  serviceUsages ServiceUsage[]

  @@map("services")
}

model ServiceUsage {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  unitPrice Float
  amount    Float
  date      DateTime @default(now())
  note      String?
  bookingId String
  serviceId String
  createdAt DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@map("service_usages")
}

// ============================================
// TASKS & AUTOMATION
// ============================================
enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  HOUSEKEEPING
  MAINTENANCE
  OTHER
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  type        TaskType   @default(HOUSEKEEPING)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  roomId      String?
  bookingId   String?
  assigneeId  String?
  propertyId  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  room     Room?    @relation(fields: [roomId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  type        TaskType @default(HOUSEKEEPING)
  description String?
  subtasks    String[] @default([])
  propertyId  String
  createdAt   DateTime @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("task_templates")
}

// ============================================
// EMAIL AUTOMATION
// ============================================
model EmailTemplate {
  id         String   @id @default(cuid())
  name       String
  subject    String
  body       String
  trigger    String? // e.g. "booking_confirmed", "check_in_reminder"
  isActive   Boolean  @default(true)
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("email_templates")
}

model EmailFlow {
  id           String   @id @default(cuid())
  name         String
  triggerEvent String
  conditions   Json?
  actions      Json?
  isActive     Boolean  @default(true)
  propertyId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("email_flows")
}

// ============================================
// CHANNEL MANAGER (OTA Integration)
// ============================================
model OtaChannel {
  id          String    @id @default(cuid())
  name        String // Booking.com, Agoda, Traveloka...
  type        String // booking_com, agoda, traveloka
  credentials Json?
  isActive    Boolean   @default(false)
  lastSyncAt  DateTime?
  propertyId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  otaMappings OtaMapping[]
  syncLogs    SyncLog[]

  @@map("ota_channels")
}

model OtaMapping {
  id             String   @id @default(cuid())
  externalRoomId String?
  externalRateId String?
  channelId      String
  roomTypeId     String
  createdAt      DateTime @default(now())

  // Relations
  channel  OtaChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  roomType RoomType   @relation(fields: [roomTypeId], references: [id])

  @@map("ota_mappings")
}

enum SyncDirection {
  PUSH
  PULL
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

model SyncLog {
  id        String        @id @default(cuid())
  action    String
  direction SyncDirection
  status    SyncStatus    @default(PENDING)
  details   Json?
  duration  Int? // milliseconds
  channelId String
  timestamp DateTime      @default(now())

  // Relations
  channel OtaChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

// ============================================
// SETTINGS — Labels, Categories, Sources, etc.
// ============================================
model Label {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#3B82F6")
  propertyId String
  createdAt  DateTime @default(now())

  // Relations
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookingLabels BookingLabel[]
  guestLabels   GuestLabel[]

  @@map("labels")
}

model BookingLabel {
  bookingId String
  labelId   String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([bookingId, labelId])
  @@map("booking_labels")
}

model GuestLabel {
  guestId String
  labelId String
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([guestId, labelId])
  @@map("guest_labels")
}

model Category {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("guest") // guest, booking
  propertyId String
  createdAt  DateTime @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("categories")
}

model BookingSource {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("direct") // direct, ota, agent
  isActive   Boolean  @default(true)
  propertyId String
  createdAt  DateTime @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("booking_sources")
}

model PaymentMethod {
  id         String   @id @default(cuid())
  name       String
  isActive   Boolean  @default(true)
  propertyId String
  createdAt  DateTime @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountNumber String
  accountName   String
  branch        String?
  isDefault     Boolean  @default(false)
  propertyId    String
  createdAt     DateTime @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}
